{
    "mcpServers": {
        "devflow-jira": {
            "command": "python",
            "args": ["mcp_server/jira_server.py"],
            "env": {
                "JIRA_URL": "${JIRA_BASE_URL}",
                "JIRA_USERNAME": "${JIRA_USER_EMAIL}",
                "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
            }
        },
        "devflow-github": {
            "command": "python",
            "args": ["mcp_server/github_server.py"],
            "env": {
                "GITHUB_TOKEN": "${GH_PAT}"
            }
        }
    }
}
