{
    "mcpServers": {
        "jira": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-atlassian"
            ],
            "env": {
                "JIRA_URL": "${JIRA_BASE_URL}",
                "JIRA_USERNAME": "${JIRA_USER_EMAIL}",
                "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
            }
        },
        "github": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-github"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GH_PAT}"
            }
        }
    }
}